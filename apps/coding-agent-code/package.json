{
  "name": "@kevin.xie.toronto/coding-agent-code",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "coding-agent": "dist/main.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "imports": {
    "#*": [
      "./src/*.ts",
      "./src/*/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsx ./src/main.ts",
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "semver": "7.7.4"
  },
  "devDependencies": {
    "@kevin.xie.toronto/agent-core": "workspace:^",
    "@types/semver": "^7.7.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
