{
  "name": "@kevin.xie.toronto/llm-provider-abstraction",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "files": ["dist"],
  "imports": {
    "#*": ["./src/*.ts", "./src/*/index.ts"]
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "undici": "7.27.1",
    "zod": "catalog:"
  }
}
